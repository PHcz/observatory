[Unit]
Description=Observatory daily soak-window evidence snapshot
After=network-online.target obs-api.service
Wants=network-online.target

[Service]
Type=oneshot
User=observatory
Group=observatory
EnvironmentFile=/etc/observatory/observatory.env
ExecStart=/opt/observatory/.venv/bin/python /opt/observatory/scripts/snapshot-soak.py
StandardOutput=journal
StandardError=journal
SyslogIdentifier=obs-soak-snapshot
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
