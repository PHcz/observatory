# EXAMPLE passwords file for Mosquitto — DO NOT use as-is on the Pi.
# On the Pi, generate the real /etc/mosquitto/passwords with:
#   sudo mosquitto_passwd -c /etc/mosquitto/passwords enviro-observatory-weather
#   sudo mosquitto_passwd /etc/mosquitto/passwords obs-api-subscriber
# mosquitto_passwd writes one line per user in the form:
#   <username>:<PBKDF2-hash>
# See deploy/mosquitto/README.md for the bootstrap-pi.sh hook.

enviro-observatory-weather:$7$101$EXAMPLE_PBKDF2_HASH_REPLACE_ME
obs-api-subscriber:$7$101$EXAMPLE_PBKDF2_HASH_REPLACE_ME
