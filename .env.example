# Observatory configuration — copy to .env on dev machine, copy to
# /etc/observatory/observatory.env on the Pi and fill in real values.
#
# IMPORTANT: comments MUST be on their own lines. systemd EnvironmentFile
# does NOT strip inline comments — `HOME_LAT=51.5  # London` would pass
# the literal string "51.5  # London" to the service.

# --- Location (required) ---
# Used for astral calculations and pre-computed lightning distance.
# Dev .env should use the London placeholder below.
# Pi /etc/observatory/observatory.env holds the real coordinates.
HOME_LAT=51.5074
HOME_LON=-0.1278

# --- Database ---
# Path to the SQLite database file. Defaults to the Pi location.
OBSERVATORY_DB_PATH=/var/lib/observatory/observatory.db

# --- MQTT broker (Phase 3+) ---
MQTT_HOST=localhost
MQTT_PORT=1883
