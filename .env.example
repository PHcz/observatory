# Observatory configuration — copy to .env on dev machine, copy to
# /etc/observatory/observatory.env on the Pi and fill in real values.
#
# IMPORTANT: comments MUST be on their own lines. systemd EnvironmentFile
# does NOT strip inline comments — `HOME_LAT=51.5  # London` would pass
# the literal string "51.5  # London" to the service.

# --- Location (required) ---
# Used for astral calculations and pre-computed lightning distance.
# Dev .env should use the London placeholder below.
# Pi /etc/observatory/observatory.env holds the real coordinates.
HOME_LAT=51.5074
HOME_LON=-0.1278

# --- Database ---
# Path to the SQLite database file. Defaults to the Pi location.
OBSERVATORY_DB_PATH=/var/lib/observatory/observatory.db

# --- MQTT broker (Phase 3+) ---
MQTT_HOST=localhost
MQTT_PORT=1883

# --- Muon detector (Phase 2) ---
# Path to the PicoMuon serial device. Created by udev rule deploy/udev/99-picomuon.rules.
MUON_SERIAL_PATH=/dev/picomuon
# Flush in-memory batch to SQLite every N seconds OR when buffer hits MUON_BUFFER_MAX.
MUON_FLUSH_INTERVAL_SEC=5
# Max events held in memory between flushes; hard cap is 10000 before oldest are dropped.
MUON_BUFFER_MAX=500
# Consecutive silence (seconds) on the serial port before reader closes + reopens.
MUON_SILENCE_TIMEOUT_SEC=60
# Max seconds to wait at startup for chronyc tracking offset to drop below 0.5s.
MUON_NTP_GATE_TIMEOUT_SEC=30

# --- External pollers (Phase 4) ---
# HTTP client hardening — per SEC-05.
# Timeouts in seconds; size cap in bytes (5 MiB).
POLLER_HTTP_CONNECT_TIMEOUT_SEC=5.0
POLLER_HTTP_READ_TIMEOUT_SEC=15.0
POLLER_HTTP_MAX_RESPONSE_BYTES=5242880
POLLER_HTTP_MAX_REDIRECTS=3
# Fail-fast threshold for individual event parse failures (0.5 = 50%).
# If parse_failures / total > threshold, poller exits non-zero (status=parse_fail).
POLLER_PARSE_FAILURE_THRESHOLD=0.5
# Per-source URL overrides (defaults are the production endpoints).
POLLER_USGS_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/4.5_day.geojson
POLLER_EMSC_URL=https://www.seismicportal.eu/fdsnws/event/1/query?format=json&limit=200&minmag=2.5
POLLER_BGS_URL=http://earthquakes.bgs.ac.uk/feeds/MhSeismology.xml
