# Copy to secrets.yaml (gitignored) and fill in real values before flashing.
# secrets.yaml must NEVER be committed — this repo is public.
wifi_ssid: "Your 2.4GHz SSID"        # ESP32 is 2.4 GHz-only
wifi_password: "your-wifi-password"
mqtt_user: "indoor-node"             # broker user (create on the Pi + ACL for indoor/#)
mqtt_password: "your-mqtt-password"
ota_password: "some-random-string"   # for wireless firmware updates
